repositories:
  - name: nvidia
    url: https://helm.ngc.nvidia.com/nvidia
  - name: open-webui
    url: https://helm.openwebui.com/

releases:
  - name: gateway-api-crds
    namespace: default
    chart: ./gateway-api

  - name: gateway-api-inference-extension-crds
    namespace: default
    chart: ./gateway-api-inference-extension

  - name: node-feature-discovery
    namespace: node-feature-discovery
    createNamespace: true
    chart: oci://registry.k8s.io/nfd/charts/node-feature-discovery
    version: "0.18.3"
    installed: {{ dig "thalamus-infra" "node-feature-discovery" "enabled" true .Values }}
    values:
      - {{ dig "thalamus-infra" "node-feature-discovery" dict .Values | toYaml | nindent 10 }}

  - name: gpu-operator
    namespace: gpu-operator
    createNamespace: true
    chart: nvidia/gpu-operator
    version: "v26.3.3"
    installed: {{ dig "thalamus-infra" "gpu-operator" "enabled" true .Values }}
    needs:
      - node-feature-discovery/node-feature-discovery
    values:
      - nfd:
          enabled: false
      - {{ dig "thalamus-infra" "gpu-operator" dict .Values | toYaml | nindent 10 }}

  - name: kube-prometheus-stack
    namespace: monitoring
    createNamespace: true
    chart: oci://ghcr.io/prometheus-community/charts/kube-prometheus-stack
    version: "87.2.1"
    installed: {{ dig "thalamus-infra" "kube-prometheus-stack" "enabled" true .Values }}
    values:
      - kubeStateMetrics:
          enabled: false
        nodeExporter:
          enabled: false
        grafana:
          enabled: false
      - {{ dig "thalamus-infra" "kube-prometheus-stack" dict .Values | toYaml | nindent 10 }}

  - name: agentgateway-crds
    namespace: agentgateway-system
    createNamespace: true
    chart: oci://cr.agentgateway.dev/charts/agentgateway-crds
    version: "v1.3.1"
    installed: {{ dig "thalamus-infra" "agentgateway-crds" "enabled" true .Values }}
    values:
      - {{ dig "thalamus-infra" "agentgateway-crds" dict .Values | toYaml | nindent 10 }}

  - name: agentgateway
    namespace: agentgateway-system
    chart: oci://cr.agentgateway.dev/charts/agentgateway
    version: "v1.3.1"
    installed: {{ dig "thalamus-infra" "agentgateway" "enabled" true .Values }}
    needs:
      - default/gateway-api-crds
      - default/gateway-api-inference-extension-crds
      - agentgateway-system/agentgateway-crds
    values:
      - inferenceExtension:
          enabled: true
      - {{ dig "thalamus-infra" "agentgateway" dict .Values | toYaml | nindent 10 }}

  - name: open-webui
    namespace: open-webui
    createNamespace: true
    chart: open-webui/open-webui
    version: "14.11.0"
    installed: {{ dig "thalamus" "open-webui" "enabled" true .Values }}
    needs:
      - thalamus/thalamus
    values:
      - ollama:
          enabled: false
        pipelines:
          enabled: false
        tika:
          enabled: false
        terminals:
          enabled: false
        extraEnvVars:
          - name: WEBUI_AUTH
            value: "False"
        service:
          type: ClusterIP
        openaiBaseApiUrl: "http://inference-gateway.thalamus.svc.cluster.local/v1"
        route:
          enabled: true
          parentRefs:
            - name: inference-gateway
              namespace: thalamus
      - {{ dig "thalamus" "open-webui" dict .Values | toYaml | nindent 10 }}

  - name: thalamus-crds
    namespace: thalamus
    createNamespace: true
    chart: ./thalamus-crds

  - name: thalamus
    chart: ./thalamus
    namespace: thalamus
    createNamespace: true
    needs:
      - thalamus/thalamus-crds
      - agentgateway-system/agentgateway
    values:
      - {{ index .Values "thalamus" | default dict | toYaml | nindent 10 }}
